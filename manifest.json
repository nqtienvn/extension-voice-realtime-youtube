{
  "manifest_version": 3,
  "name": "YouTube Caption Voice",
  "version": "0.3.2",
  "description": "Đọc phụ đề YouTube bằng giọng tùy chọn và ghi lại nội dung để tải xuống.",
  "permissions": ["storage"],
  "host_permissions": ["https://youtube.com/*", "https://*.youtube.com/*"],
  "action": {
    "default_title": "YouTube Caption Voice",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://youtube.com/*", "https://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
