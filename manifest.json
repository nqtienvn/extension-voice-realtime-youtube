{
  "manifest_version": 3,
  "name": "YouTube Caption Voice",
  "version": "0.2.4",
  "description": "Đọc ngay phụ đề YouTube bằng giọng tiếng Việt của trình duyệt hoặc hệ thống.",
  "permissions": ["storage"],
  "host_permissions": ["https://youtube.com/*", "https://*.youtube.com/*"],
  "action": {
    "default_title": "YouTube Caption Voice",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://youtube.com/*", "https://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
